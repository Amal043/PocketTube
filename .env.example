# Supabase Connection Settings
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# n8n Webhook Settings
# Note: For local docker, this might be http://localhost:5678/webhook/...
# For Render, it will be https://n8n-service-name.onrender.com/webhook/...
VITE_N8N_INGEST_WEBHOOK_URL=http://localhost:5678/webhook/your-ingest-webhook-path
VITE_N8N_RATE_WEBHOOK_URL=http://localhost:5678/webhook/your-rate-webhook-path

# YouTube Data API Keys (Comma-separated list of keys for in-app video embed pre-validation)
VITE_YOUTUBE_API_KEYS=key1,key2,key3
